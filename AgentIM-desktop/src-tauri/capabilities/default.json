{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "AgentIM desktop default permissions",
  "windows": ["main"],
  "permissions": [
    {
      "identifier": "http:default",
      "allow": [
        { "url": "http://localhost:*" },
        { "url": "http://127.0.0.1:*" },
        { "url": "https://localhost:*" },
        { "url": "https://127.0.0.1:*" },
        { "url": "http://[::1]:*" },
        { "url": "https://[::1]:*" }
      ]
    }
  ]
}
